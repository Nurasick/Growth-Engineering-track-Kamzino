# Copy to .env and fill in your keys
# Only YOUTUBE_API_KEY is required for YouTube scraping
# All other scrapers work without any API keys

YOUTUBE_API_KEY=your_key_here

# ── AI Counter-Playbook Generator (Part 4) ───────────────────────────────────
# Set ONE of these. Script auto-detects which is present.
# Priority order: OPENAI → ANTHROPIC → GEMINI

OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here

# Optional: force a specific provider (openai | anthropic | gemini)
# PLAYBOOK_AI_PROVIDER=openai
